[sub_resource type="GDScript" id="GDScript_2jcn1"]
script/source = "shader_type canvas_item;

uniform float darken_amount = 0.5;

void fragment() {
	vec4 tex_color = texture(TEXTURE, UV);
	COLOR = vec4(tex_color.rgb * (1.0 - darken_amount), tex_color.a);
}
"

